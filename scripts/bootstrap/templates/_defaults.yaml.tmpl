import:
  - orgs/_defaults

vars:
  namespace: {{ .namespace }}
  region: {{ .primary_region }}
  tags:
    ManagedBy: atmos-aft
    Org: {{ .org_name }}
  separate_aft_mgmt_account: {{ .separate_aft_mgmt_account }}

settings:
  aft_mgmt_account_id: "{{ .aft_mgmt_account_id }}"
  ct_mgmt_account_id: "{{ .management_account_id }}"
  audit_account_id: "{{ .audit_account_id }}"
  log_archive_account_id: "{{ .log_archive_account_id }}"
  primary_region: {{ .primary_region }}
  aws_auth_mode: {{ .aws_auth_mode }}
  dispatch_auth_mode: {{ .dispatch_auth_mode }}
  ct_landing_zone_id: "{{ .ct_landing_zone_id }}"
  github_org: {{ .github_org }}
  github_repo: {{ .github_repo }}
